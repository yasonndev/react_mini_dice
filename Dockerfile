# Используем стабильную версию Node.js
FROM node:20-alpine

# Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# Копируем файлы зависимостей из папки app
COPY app/package*.json ./

# Устанавливаем зависимости
RUN npm install

# Копируем остальной код из папки app в текущую директорию контейнера (/app)
COPY app/ .

# Открываем порт (обычно 5173 для Vite или 3000 для CRA)
EXPOSE 5173

# Запускаем приложение
CMD ["npm", "run", "dev", "--", "--host"]